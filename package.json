{
  "name": "roam-v4",
  "version": "0.1.0",
  "description": "Roam v4 — AIOS-style backend + sidebar-panel UI for your home computer",
  "type": "module",
  "main": "server/main/index.js",
  "scripts": {
    "postinstall": "node scripts/fix-node-pty.js",
    "predev": "node scripts/start.mjs",
    "dev": "ROAM_APPS_PORT=9507 node server/main/index.js --port=9506 & node server/apps/index.js --port=9507 & vite --config gui/vite.config.js gui",
    "prebuild": "node scripts/start.mjs",
    "build": "vite build --config gui/vite.config.js gui",
    "prestart": "node scripts/start.mjs",
    "start": "node scripts/run.mjs",
    "start:main": "ROAM_APPS_PORT=9507 node server/main/index.js --port=9506",
    "start:apps": "node server/apps/index.js --port=9507",
    "lang:apply": "node scripts/start.mjs --force",
    "lang:reset": "rm -rf .aios"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "@vitejs/plugin-vue": "^6.0.4",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "better-sqlite3": "^12.6.2",
    "lucide-vue-next": "^0.576.0",
    "marked": "^17.0.2",
    "node-pty": "^1.1.0",
    "pinia": "^3.0.4",
    "tailwindcss": "^4.1.18",
    "vite": "^7.3.1",
    "vue": "^3.5.28",
    "vue-router": "^4.6.4",
    "ws": "^8.19.0"
  }
}
